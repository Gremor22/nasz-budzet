# Skopiuj ten plik jako `.env.local` i uzupełnij wartości z Supabase.
# Project Settings → API
#
# Możesz użyć klasycznego „anon” JWT albo nowego „publishable” key.
# NIGDY nie wklejaj secret / service_role do przeglądarki ani do Gita.

NEXT_PUBLIC_SUPABASE_URL=https://TWOJ-PROJEKT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=twoj_publishable_lub_anon_key

# --- Etap 5: OCR (TYLKO po stronie serwera / Vercel, bez NEXT_PUBLIC_) ---
# Domyślnie: auto → Gemini (jeśli klucz) → inaczej Tesseract w telefonie
# OCR_PROVIDER=auto
#
# Google AI Studio — darmowy limit (zalecane do lepszej jakości):
# https://aistudio.google.com/apikey
# GEMINI_API_KEY=
# GEMINI_OCR_MODEL=gemini-2.0-flash-lite
#
# Opcjonalnie płatne OpenAI:
# OCR_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_OCR_MODEL=gpt-4o-mini
